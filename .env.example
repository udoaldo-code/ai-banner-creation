# ─────────────────────────────────────────────────────────────────────────────
# AI Banner Generator — Environment Variables
#
# Copy this file to .env.local for local development:
#   cp .env.example .env.local
#
# For production, set these as environment variables in your hosting platform.
# Variables marked [REQUIRED] will cause a hard failure if missing.
# Variables marked [OPTIONAL] have safe defaults or graceful fallbacks.
# Variables marked [SECRET] must be kept out of source control and logs.
# ─────────────────────────────────────────────────────────────────────────────


# ── Database ──────────────────────────────────────────────────────────────────
# [REQUIRED] [SECRET]
# Full PostgreSQL connection string.
# Local:      postgresql://user:password@localhost:5432/banner_gen
# Railway:    postgresql://postgres:<pw>@<host>.railway.app:5432/railway
# Supabase:   postgresql://postgres:<pw>@<host>.supabase.co:6543/postgres?pgbouncer=true
# Neon:       postgresql://user:<pw>@<host>.neon.tech/banner_gen?sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/banner_gen"

# [OPTIONAL] — required only if using Prisma with PgBouncer (e.g. Supabase pooled)
# Use the direct (non-pooled) URL for migrations; the pooled URL for the app.
# DIRECT_URL="postgresql://user:password@localhost:5432/banner_gen"


# ── NextAuth ──────────────────────────────────────────────────────────────────
# [REQUIRED] [SECRET]
# Random string used to sign/encrypt JWT tokens and CSRF cookies.
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-output-of-openssl-rand-base64-32"

# [REQUIRED]
# The canonical public URL of the web app (no trailing slash).
# Local:      http://localhost:3000
# Production: https://your-app.vercel.app  (or custom domain)
NEXTAUTH_URL="http://localhost:3000"


# ── Anthropic (AI Banner Generation) ─────────────────────────────────────────
# [REQUIRED] [SECRET]
# API key for Claude. Create at: https://console.anthropic.com/
# The app uses claude-opus-4-6 by default (configurable in lib/ai.ts).
ANTHROPIC_API_KEY="sk-ant-api03-..."


# ── Object Storage (AWS S3 or S3-compatible) ──────────────────────────────────
# [REQUIRED] [SECRET]
# Used for: generated banner HTML, request attachments, template logos.
#
# AWS S3:
#   Create an IAM user with s3:GetObject / s3:PutObject / s3:DeleteObject
#   on your bucket. Enable public read or use presigned URLs (default).
#
# Cloudflare R2 (recommended — no egress fees):
#   Set S3_ENDPOINT to your R2 endpoint.
#   S3_REGION can be "auto" for R2.
#
S3_ACCESS_KEY_ID="AKIAIOSFODNN7EXAMPLE"
S3_SECRET_ACCESS_KEY="wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY"
S3_REGION="us-east-1"
S3_BUCKET_NAME="banner-generator-assets"

# [OPTIONAL] — only needed for R2 or other S3-compatible providers
# S3_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"


# ── Slack ─────────────────────────────────────────────────────────────────────
# [OPTIONAL] — app works without Slack; all Slack calls are no-ops if not set.
#
# Create a Slack app at https://api.slack.com/apps
# Required OAuth scopes:
#   chat:write          — post messages
#   chat:write.public   — post to channels the bot is not a member of
#   views:open          — open modals for review actions
#   users:read.email    — (future) look up users by email for DMs
#
# After installing the app to your workspace:
#   SLACK_BOT_TOKEN      — Bot User OAuth Token (xoxb-...)
#   SLACK_SIGNING_SECRET — App Credentials → Signing Secret

SLACK_BOT_TOKEN="xoxb-..."
SLACK_SIGNING_SECRET="your-signing-secret"

# Channel where new request notifications are posted (e.g. #banner-requests)
SLACK_NOTIFY_CHANNEL="#banner-requests"

# Channel where review-ready notifications with approval buttons are posted
SLACK_APPROVER_CHANNEL="#banner-approvals"

# [OPTIONAL] — set this to enable the interactive Slack webhook for approvals
# Must be the public URL for: POST /api/webhooks/slack
# In Slack app settings: Interactivity & Shortcuts → Request URL
# SLACK_WEBHOOK_URL="https://your-app.vercel.app/api/webhooks/slack"


# ── Application ───────────────────────────────────────────────────────────────
# [REQUIRED]
# Public base URL — used to build deep links in Slack messages.
# Must match NEXTAUTH_URL in production.
NEXT_PUBLIC_APP_URL="http://localhost:3000"


# ── Generation Worker (Node.js long-running server only) ─────────────────────
# If deploying on Vercel (serverless), generation runs inline via Next.js
# `after()` — no extra config needed but watch the 60s function timeout.
#
# If running a dedicated Node.js server (e.g. Railway, Fly.io), the current
# setImmediate transport in lib/jobs.ts works out of the box.
#
# For high-volume production, replace setImmediate with a proper job queue
# (pgBoss, BullMQ, Inngest) and set the queue connection string here:
# JOB_QUEUE_URL="postgresql://user:password@localhost:5432/banner_gen"
